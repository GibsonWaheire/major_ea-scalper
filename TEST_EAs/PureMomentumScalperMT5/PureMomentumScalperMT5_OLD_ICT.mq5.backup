int atrHandle = INVALID_HANDLE;
int fastEMA_HTF = INVALID_HANDLE;
int slowEMA_HTF = INVALID_HANDLE;
int fastEMA_Entry = INVALID_HANDLE;
int slowEMA_Entry = INVALID_HANDLE;
int rsiHandle = INVALID_HANDLE;
